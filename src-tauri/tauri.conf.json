{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "qPCR_oligo_inclusivity_tool",
  "version": "3.0.0",
  "identifier": "com.lab.qpcr-oligo-inclusivity",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "qPCR Oligo Inclusivity Tool V3 (Tauri)",
        "width": 950,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
